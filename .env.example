PORT=8787
HOST=127.0.0.1

# Required when HOST is not a loopback address.
WORKBENCH_ACCESS_TOKEN=
WORKBENCH_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Local data and logging
WORKBENCH_DATA_DIR=./data
WORKBENCH_LOG_LEVEL=info
WORKBENCH_LOG_MAX_BYTES=5242880
WORKBENCH_LOG_MAX_FILES=3

# 以下 provider 配置均可直接在网页“配置”中填写。
# 环境变量适合自动化部署，也会作为网页配置的默认值。

# 火山引擎新版控制台（可选）
VOLCENGINE_ASR_API_KEY=

# 如果你使用旧版控制台，也可以填下面两项（可选）
VOLCENGINE_ASR_APP_KEY=
VOLCENGINE_ASR_ACCESS_KEY=

# ASR 2.0 默认更适合说话人分离；如果你的资源不是这个，按控制台实际值替换
VOLCENGINE_ASR_RESOURCE_ID=volc.seedasr.sauc.duration
VOLCENGINE_ASR_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async

# DeepSeek 或其他兼容 OpenAI 的 API（可选）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_MS=75000
