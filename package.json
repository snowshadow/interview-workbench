{
  "name": "interview-workbench",
  "version": "0.1.0",
  "description": "Local-first realtime interview transcription and LLM follow-up workbench",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/snowshadow/interview-workbench.git"
  },
  "homepage": "https://github.com/snowshadow/interview-workbench#readme",
  "bugs": {
    "url": "https://github.com/snowshadow/interview-workbench/issues"
  },
  "keywords": [
    "interview",
    "speech-to-text",
    "llm",
    "local-first"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "dev": "concurrently -k \"node --watch server/index.js\" \"vite --host 127.0.0.1\"",
    "build": "vite build",
    "start": "node server/index.js",
    "check": "node scripts/check.mjs",
    "check:package": "node scripts/check-package.mjs",
    "test": "node --test test/*.test.js",
    "release:check": "npm run check && npm test && npm run build && npm run check:package"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.3",
    "vite": "^8.1.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
